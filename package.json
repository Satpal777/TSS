{
  "name": "tea-simple-smart-css",
  "version": "1.0.0",
  "description": "A zero-config, lightweight utility-first CSS engine with automatic light/dark mode.",
  "type": "module",
  "module": "dist/tss.esm.js",
  "unpkg": "dist/tss.min.js",
  "jsdelivr": "dist/tss.min.js",
